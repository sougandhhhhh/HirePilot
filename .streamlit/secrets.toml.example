# HirePilot AI – Streamlit secrets (copy to .streamlit/secrets.toml, never commit the real file)
# On Streamlit Community Cloud: paste these values in the app Settings → Secrets panel.

WATSONX_API_KEY       = "your_ibm_cloud_api_key_here"
WATSONX_PROJECT_ID    = "your_watsonx_project_id_here"
WATSONX_SPACE_ID      = "your_deployment_space_id_here"
WATSONX_API_URL       = "https://us-south.ml.cloud.ibm.com"
USE_MOCK_DATA         = true
