# HirePilot AI – Environment Variables
# Copy this file to .env and fill in your IBM watsonx credentials.

# ── IBM watsonx.ai ───────────────────────────────────────────
WATSONX_API_URL=https://us-south.ml.cloud.ibm.com
WATSONX_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_SPACE_ID=your_deployment_space_id_here

# ── Feature Flags ────────────────────────────────────────────
# Set to False to use live IBM watsonx agents instead of demo data
USE_MOCK_DATA=True
